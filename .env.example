# livingATL — environment variable template
#
# Two env files, two purposes (see CLAUDE.md "Env file separation"):
#   - livingatl/.env.local       — Next.js app (web)
#   - livingatl-pipeline/.env    — Python pipeline (transcribe/diarize/ingest)
#
# Neither is committed. Copy the relevant sections below into each file and
# fill in real values. `scripts/ingest.py` also reads livingatl/.env.local
# as a fallback for DATABASE_URL / OPENAI_API_KEY — so it's fine to put the
# shared secrets in either file, as long as they exist somewhere.
#
# Vercel deploy: set the "Web app" section as Vercel project env vars.
# Pipeline runs locally on the project lead's Mac, not in the cloud, so the
# pipeline section stays on disk and never lands in Vercel.

# ==============================================================================
# Web app  →  livingatl/.env.local
# ==============================================================================

# Supabase Postgres — USE THE POOLER CONNECTION when deployed (port 6543,
# pgbouncer transaction mode). Local dev can use the direct connection.
# Example pooler: postgres://postgres.<project>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Launch gate (PRD §8.8). When "true", src/proxy.ts stops rewriting every
# non-allowlisted route to /preview. Leave unset / "false" for invite-only.
# For the password-gated public demo, set this "true" so the per-page/per-API
# backstops render real content — the demo password (below) is what keeps the
# public out, not this flag.
NEXT_PUBLIC_LAUNCH_ENABLED=false

# Demo password gate — "fake security" for a public preview. When
# SITE_GATE_TOKEN is set, src/proxy.ts rewrites every non-allowlisted request
# to /gate until the visitor enters SITE_GATE_PASSWORD (set by /api/gate via an
# httpOnly cookie). Leave SITE_GATE_TOKEN unset to disable the gate entirely
# and fall back to launch-gate/preview behavior. Both are server-only.
#   SITE_GATE_PASSWORD — what the visitor types (pick anything memorable).
#   SITE_GATE_TOKEN    — opaque cookie value; generate with `openssl rand -hex 32`.
SITE_GATE_PASSWORD=
SITE_GATE_TOKEN=

# Mapbox GL token for the /map surface. Restrict to your domain +
# localhost in the Mapbox dashboard once you know the Vercel URL so the
# token can't be scraped and used against your quota.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Sentry — runtime error + trace capture.
# NEXT_PUBLIC_SENTRY_DSN ships in the client bundle (expected for Sentry).
# SENTRY_DSN is the server-side value; same DSN as the NEXT_PUBLIC_ variant
# is fine, but you can also scope server events to a separate project.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Sentry source-map upload — required at BUILD time only (Vercel build step).
# Create a Sentry Internal Integration with project:releases + project:write
# scopes; paste the token here. `silent: !process.env.CI` in next.config.ts
# skips uploads outside CI so local builds don't need these values set.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — product analytics (PRD §1 metrics). Both ship in the client
# bundle. Host defaults to https://us.i.posthog.com if unset. Init is silent
# when the key is missing, so these are optional for a demo.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Set automatically by Vercel — do NOT set manually in local .env files.
# Listed here for completeness; instrumentation-client.ts reads it for the
# Sentry "environment" tag.
# NEXT_PUBLIC_VERCEL_ENV=

# LLM synthesis provider (AI Portal §7.4 + story gen §7.6). Resolved by
# src/lib/ai/provider.ts → getSynthesisModel(). Server-side only — never
# expose as NEXT_PUBLIC_*. Flip to LLM_PROVIDER=anthropic + populate
# ANTHROPIC_API_KEY below to swap providers; no code change required.
LLM_PROVIDER=openai
LLM_MODEL_SYNTHESIS=gpt-4o-mini

# Anthropic API key — required ONLY when LLM_PROVIDER=anthropic.
# Get one at https://console.anthropic.com/settings/keys (Claude Code
# subscription auth cannot be reused for SDK calls).
ANTHROPIC_API_KEY=

# OpenAI — required always. Used for:
#   1. Embeddings (text-embedding-3-small) in the pipeline and any server
#      code that re-embeds at runtime.
#   2. LLM synthesis when LLM_PROVIDER=openai (default).
OPENAI_API_KEY=

# Shared secret for POST /api/revalidate (tag-based cache invalidation).
# Generate with `openssl rand -hex 32`. The same value must be set in the
# pipeline .env below so scripts/ingest.py can call the webhook after a
# successful ingest. Without it, caches fall back to TTL (1h / 24h).
REVALIDATE_SECRET=

# ==============================================================================
# Pipeline  →  livingatl-pipeline/.env
# ==============================================================================

# Same Postgres as above, but use the DIRECT connection (port 5432) since
# the pipeline runs long transactions that pgbouncer transaction mode can't
# hold. Example direct: postgres://postgres:<password>@db.<project>.supabase.co:5432/postgres
# DATABASE_URL=

# OpenAI — text-embedding-3-small for chunk embeddings (ingest.py).
OPENAI_API_KEY=

# HuggingFace — pyannote.audio diarization + wespeaker embeddings
# (diarize.py). Must accept license terms on BOTH model pages:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/wespeaker-voxceleb-resnet34-LM
# Same token, three click-throughs.
HF_TOKEN=

# Cloudflare R2 — public base URL for streamed audio (optional until audio
# hosting moves off local disk). Used by ingest.py to populate
# recordings.audio_url.
R2_PUBLIC_URL=

# App-side cache invalidation webhook. When both are set, scripts/ingest.py
# POSTs to ${LIVINGATL_BASE_URL}/api/revalidate?tag=<tag> after every
# successful ingest batch (tags: facets, archive-stats, neighborhoods).
# Unset → the ingest still succeeds; the Browser/Map facets just wait
# for their TTL to expire (1h / 24h). REVALIDATE_SECRET must match the
# same env var in livingatl/.env.local.
LIVINGATL_BASE_URL=
REVALIDATE_SECRET=
